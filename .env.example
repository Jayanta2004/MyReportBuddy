# ─────────────────────────────────────────────────────────
#  MyReportBuddy — Environment Variables
# ─────────────────────────────────────────────────────────
#  Copy this file to .env.local and fill in your values.
#  Never commit .env.local to source control.

# ── OpenAI ────────────────────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here


# ── Supabase (optional — enables report history) ──────────
#
#  Setup steps:
#  1. Create a free project at https://supabase.com
#
#  2. Get your Project URL and Service Role key from:
#     Project → Settings → API
#       • "Project URL"           → SUPABASE_URL
#       • "service_role" secret   → SUPABASE_SERVICE_ROLE_KEY
#
#  3. Create the reports table — run this SQL once in:
#     Project → SQL Editor → New query
#
#     CREATE TABLE IF NOT EXISTS reports (
#       id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
#       file_name       TEXT NOT NULL,
#       file_type       TEXT NOT NULL,
#       file_size       INTEGER NOT NULL,
#       uploaded_at     TIMESTAMPTZ NOT NULL DEFAULT NOW(),
#       processed_at    TIMESTAMPTZ,
#       status          TEXT NOT NULL DEFAULT 'PENDING',
#       analysis_result JSONB,
#       report_type     TEXT,
#       error_message   TEXT
#     );
#
#  Leave both vars empty (or remove them) to run without history.
#
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ── Rate limiting ─────────────────────────────────────────
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
