# ── Dependencies ─────────────────────────────────────────────
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js ──────────────────────────────────────────────────
/.next/
/out/
/build

# ── Environment & secrets ─────────────────────────────────────
# Never commit real keys — copy .env.example to .env.local
.env
.env.local
.env.*.local
.env.production

# ── User uploads (runtime files, never commit) ───────────────
/uploads/*
!/uploads/.gitkeep

# ── Testing & coverage ───────────────────────────────────────
/coverage
*.lcov

# ── Logs ─────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── OS / editor artefacts ────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/settings.json

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ───────────────────────────────────────────────────
.vercel
